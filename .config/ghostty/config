# Config generated by Ghostty Config

working-directory = home
confirm-close-surface = false
quit-after-last-window-closed = true
shell-integration = zsh
shell-integration-features = cursor, sudo, title
term = "xterm-256color"
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
window-decoration = true
background-opacity = 1.0
background-blur = 100
unfocused-split-opacity = 0.95
unfocused-split-fill = #1e2030
theme = Zenwritten Dark
foreground = #cad3f5
selection-background = #5b6078
selection-foreground = #cad3f5
selection-invert-fg-bg = true
cursor-color = #f4dbd6
cursor-text = #24273a
font-size = 14
font-thicken = true
font-family = monospace
adjust-cursor-thickness = 1
keybind = super+left=previous_tab
keybind = super+right=next_tab
keybind = shift+enter=text:\n
macos-icon = microchip
