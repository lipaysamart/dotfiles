{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "model": "bailian-coding-plan/glm-5",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-openagent@latest"
  ],
  "permission": {
    "bash": {
      "git push --force*": "deny",
      "wget *|bash*": "deny",
      "wget *| bash*": "deny",
      "git push *--force*": "deny",
      "git reset --hard*": "deny",
      "rm -rf": "deny",
      "rm -fr": "deny",
      "mkfs": "deny",
      "dd": "deny"
    },
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.aws/**": "deny",
      "~/.aliyun/**": "deny",
      "~/.config/gh/**": "deny",
      "~/.git-credentials": "deny",
      "~/.docker/config.json": "deny",
      "~/.kube/**": "deny",
      "~/.npmrc": "deny",
      "~/.npm/**": "deny",
      "~/.pypirc": "deny",
      "~/.gem/credentials)": "deny",
      "~/Library/Keychains/**": "deny"
    },
    "edit": {
      "~/.bashrc": "deny",
      "~/.zshrc": "deny",
      "~/.ssh/**": "deny"
    }
  },
  "provider": {
    "bailian-coding-plan": {
      "npm": "@ai-sdk/anthropic",
      "name": "Aliyun Coding Plan",
      "options": {
        "baseURL": "https://coding.dashscope.aliyuncs.com/apps/anthropic/v1",
        "apiKey": "{env:BAILIAN_API_KEY}"
      },
      "models": {
        "qwen3-coder-plus": {
          "name": "Qwen3 Coder Plus",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "MiniMax-M2.5": {
          "name": "MiniMax M2.5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "glm-5": {
          "name": "GLM-5",
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 16000
            }
          }
        }
      }
    }
  }
}
