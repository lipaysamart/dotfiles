{
  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": false,
  "piInfrastructureReadPaths": [],

  "permission": {
    "*": "allow", 
    "path": {
      "*": "allow",
      "~/.ssh/*": "deny"
    },

    "read": {
      "~/.gnupg/*": "deny",
      "~/.aws/*": "deny",
      "~/.aliyun/*": "deny",
      "~/.config/gh/*": "deny",
      "~/.git-credentials": "deny",
      "~/.docker/config.json": "deny",
      "~/.kube/*": "deny",
      "~/.npmrc": "deny",
      "~/.npm/*": "deny",
      "~/.pypirc": "deny",
      "~/.gem/credentials": "deny",
      "~/Library/Keychains/*": "deny"
    },

    "edit": {
      "~/.bashrc": "deny",
      "~/.zshrc": "deny",
      "~/.zshrc.local": "deny"
    },

    "bash": {
      "git push --force *": "deny",
      "wget * | bash *": "deny",
      "git push * --force *": "deny",
      "git reset --hard *": "deny",
      "rm -rf *": "deny",
      "mkfs *": "deny",
      "dd *": "deny"
    },

    "external_directory": {
      "*": "ask",
      "/tmp/*": "allow",
      "~/Code/*": "allow"
    }
  }
}
