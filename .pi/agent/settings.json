{
  "lastChangelogVersion": "0.75.5",
  "defaultProvider": "opencode-go",
  "defaultModel": "deepseek-v4-flash",
  "subagents": {
    "agentOverrides": {
      "reviewer": {
        "model": "opencode-go/glm-5.1",
        "thinking": "high"
      },
      "oracle": {
        "model": "opencode-go/glm-5.1",
        "thinking": "high"
      },
      "planner": {
        "model": "opencode-go/deepseek-v4-pro",
        "thinking": "medium"
      },
      "researcher": {
        "model": "opencode-go/kimi-k2.6"
      },
      "worker": {
        "model": "opencode-go/deepseek-v4-pro"
      },
      "scout": {
        "model": "opencode-go/qwen3.6-plus"
      }
    }
  },
  "packages": [
    "pi-skills",
    "npm:pi-permission-system@0.4.9",
    "npm:pi-subagents@0.25.0",
    "npm:pi-mcp-adapter@2.5.4",
    "npm:pi-web-access@0.10.7",
    "npm:pi-intercom@0.6.0",
    "npm:pi-powerline-footer@0.5.4",
    "npm:@juicesharp/rpiv-ask-user-question@1.12.0",
    "npm:@juicesharp/rpiv-todo@1.12.0",
    "npm:@capyup/pi-goal@0.6.0"
  ],
  "enableSkillCommands": false,
  "retry": {
    "enabled": true,
    "maxRetries": 3
  },
  "skills": [
    "~/.agents/skills"
  ],
  "prompts": [
    "~/.agents/commands"
  ],
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "defaultThinkingLevel": "off",
  "powerline": {
    "preset": "default",
    "fixedEditor": false,
    "customItems": [],
    "mouseScroll": false
  },
  "powerlineShortcuts": {
    "stashHistory": "ctrl+alt+h",
    "copyEditor": "ctrl+alt+c",
    "cutEditor": "ctrl+alt+x",
    "jumpPreviousUserMessage": "ctrl+shift+u",
    "jumpNextUserMessage": "ctrl+shift+i",
    "jumpPreviousLlmMessage": "ctrl+alt+,",
    "jumpNextLlmMessage": "ctrl+alt+.",
    "jumpChatBottom": "ctrl+shift+g",
    "scrollChatUp": "cmd+up",
    "scrollChatDown": "cmd+down",
    "editorStart": "cmd+shift+up",
    "editorEnd": "cmd+shift+down"
  },
  "bashMode": {
    "toggleShortcut": "ctrl+shift+b",
    "transcriptMaxLines": 2000,
    "transcriptMaxBytes": 524288
  },
  "workingVibe": "star trek",
  "workingVibeMode": "file",
  "workingVibeModel": "bailian/glm-5",
  "workingVibeFallback": "Working",
  "workingVibeRefreshInterval": 30,
  "workingVibeMaxLength": 65,
  "enabledModels": [
    "opencode-go/deepseek-v4-flash",
    "opencode-go/deepseek-v4-pro",
    "opencode-go/glm-5.1",
    "opencode-go/qwen3.6-plus",
    "nvidia/google/gemma-4-31b-it",
    "nvidia/deepseek-ai/deepseek-v4-pro",
    "nvidia/moonshotai/kimi-k2.6",
    "nvidia/z-ai/glm-5.1",
    "metis/metis-coder",
    "metis/metis-coder-max",
    "metis/metis-coder-plus",
    "metis/metis-coder-ultra"
  ]
}